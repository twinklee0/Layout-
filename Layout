import 'package:flutter/material.dart';

void main() {
  runApp(LayoutDemo());
}

class LayoutDemo extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(title: Text("Flutter Layouts")),
        body: SingleChildScrollView(
          child: Column(
            children: [
              Text("Row Layout"),
              Row(
                mainAxisAlignment: MainAxisAlignment.spaceEvenly,
                children: [
                  Container(color: Colors.red, width: 50, height: 50),
                  Container(color: Colors.green, width: 50, height: 50),
                  Container(color: Colors.blue, width: 50, height: 50),
                ],
              ),
              SizedBox(height: 20),
              Text("Column Layout"),
              Column(
                children: [
                  Container(color: Colors.orange, width: 100, height: 50),
                  Container(color: Colors.purple, width: 100, height: 50),
                  Container(color: Colors.yellow, width: 100, height: 50),
                ],
              ),
              SizedBox(height: 20),
              Text("Stack Layout"),
              Stack(
                alignment: Alignment.center,
                children: [
                  Container(color: Colors.grey, width: 150, height: 150),
                  Container(color: Colors.black, width: 100, height: 100),
                  Container(color: Colors.white, width: 50, height: 50),
                ],
              ),
              SizedBox(height: 20),
              Text("Grid Layout"),
              Container(
                height: 200,
                child: GridView.count(
                  crossAxisCount: 3,
                  children: List.generate(6, (index) {
                    return Container(
                      margin: EdgeInsets.all(5),
                      color: Colors.teal,
                    );
                  }),
                ),
              ),
              SizedBox(height: 20),
              Text("ListView Layout"),
              Container(
                height: 200,
                child: ListView(
                  children: [
                    ListTile(title: Text("Item 1")),
                    ListTile(title: Text("Item 2")),
                    ListTile(title: Text("Item 3")),
                    ListTile(title: Text("Item 4")),
                  ],
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
